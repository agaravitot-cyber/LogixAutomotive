<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="parqueaderoapp.controller.empleadoController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="400.0" prefWidth="216.0">
         <children>
            <Label text="Registro de Vehiculos">
               <VBox.margin>
                  <Insets top="60.0" />
               </VBox.margin>
            </Label>
            <Label text="Tipo de vehiculo">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <ComboBox fx:id="tipo" prefWidth="150.0">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </ComboBox>
            <Label text="Placa">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="entradaPlaca" promptText="Ingrese Placa">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </TextField>
            <Button fx:id="entradaBtn" mnemonicParsing="false" onAction="#onRegistrarEntrada" text="Registrar entrada">
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" layoutX="213.0" prefHeight="400.0" prefWidth="216.0">
         <children>
            <Label text="Salida de vehiculos">
               <VBox.margin>
                  <Insets top="60.0" />
               </VBox.margin>
            </Label>
            <Label text="Placa">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="salidaPlaca" promptText="Ingrese Placa">
               <VBox.margin>
                  <Insets left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </TextField>
            <Button fx:id="salidaBtn" mnemonicParsing="false" onAction="#onRegistrarSalida" text="Generar recibo">
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="regresoBtn" mnemonicParsing="false" onAction="#onBack" text="Atras">
               <VBox.margin>
                  <Insets top="30.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" layoutX="429.0" prefHeight="400.0" prefWidth="172.0">
         <children>
            <Label text="Estado Parqueadero">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Accordion fx:id="estadoAccordeon">
              <panes>
                <TitledPane animated="false" text="untitled 1" />
                <TitledPane animated="false" text="untitled 2" />
              </panes>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Accordion>
         </children>
      </VBox>
   </children>
</AnchorPane>
