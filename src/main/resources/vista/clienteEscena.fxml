               </VBox.margin>
            </Button>
         </children>
      </VBox>
      <VBox alignment="TOP_CENTER" layoutX="300.0" prefHeight="400.0" prefWidth="300.0">
         <children>
            <Label text="Consulta disponibilidad">
               <VBox.margin>
                  <Insets top="100.0" />
               </VBox.margin>
            </Label>
            <Button mnemonicParsing="false" onAction="#onConsultarDisponibilidad" prefHeight="102.0" prefWidth="118.0" text="Consultar">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="regresoBtn" mnemonicParsing="false" onAction="#onBack" text="Atras">
               <VBox.margin>
                  <Insets top="50.0" />
